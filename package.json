{
  "name": "campus-system",
  "version": "1.0.0",
  "private": true,
  "description": "校园通信与文件传输系统 — Monorepo with pnpm + Turborepo + NestJS + React",
  "scripts": {
    "web": "pnpm --filter @campus-im/frontend dev",
    "backend": "pnpm --filter @campus-im/backend start:dev",
    "all": "concurrently \"pnpm run web\" \"pnpm run backend\"",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "setup": "pnpm install && cd apps/backend && pnpm dlx prisma migrate dev --name init && pnpm dlx prisma generate",
    "clean": "pnpm -r exec rm -rf node_modules dist .turbo",
    "start:db": "docker run --name campus-im-db -e POSTGRES_PASSWORD=password -p 5432:5432 -d postgres",
    "start:backend": "pnpm --filter backend start:dev",
    "start:frontend": "pnpm --filter frontend dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "turbo": "latest"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.7.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "concurrently": "^10.0.3"
  }
}
